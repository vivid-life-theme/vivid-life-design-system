{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(rm -rf:*)"
    ],
    "allow": [
      "Bash(node tools/build-tokens.mjs*)",
      "Bash(node tools/build-css.mjs*)",
      "Bash(node tools/build-previews.mjs*)",
      "Bash(npm run build)",
      "Bash(npm run check)",
      "Bash(npm run test)"
    ]
  },
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50"
  }
}
