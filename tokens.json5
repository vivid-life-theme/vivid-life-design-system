// ════════════════════════════════════════════════════════════════════
// Vivid Life Theme — Foundation Tokens
// ────────────────────────────────────────────────────────────────────
// This file is the SINGLE SOURCE OF TRUTH for the design system.
// Any downstream port (VS Code, Alacritty, GTK, web site, …) MUST
// read its colors / type / spacing / etc. from here. If a port needs
// a value not defined here, that's a foundation gap — open an issue
// against this file, not the port.
//
// Format: JSON5 (https://json5.org). Comments, trailing commas, and
// unquoted keys are allowed. Run `node tools/build-tokens.mjs` to emit
// `tokens.json` (strict JSON for tooling that can't parse JSON5).
//
// String values that begin with "$" are REFERENCES, resolved by the
// build script:  "$palette.red.500" → "#ef4444"
//
// Version 0.3.0 · May 2026
// ════════════════════════════════════════════════════════════════════
{
  meta: {
    name: "Vivid Life Theme",
    version: "0.3.0",
    description: "A multi-flavor color scheme system. 4 flavors × 6 variants = 24 themes.",
    source_palette: "https://farben.van-laar.de/",
    inspiration: ["https://catppuccin.com/", "https://draculatheme.com/"],
  },

  // ────────────────────────────────────────────────────────────────
  //   1.  PALETTE  —  the atomic colors
  // ────────────────────────────────────────────────────────────────
  // 7 hues × 5 shades, drawn from Tailwind v3 defaults.
  // The user's palette source calls them: Rot, Orange, Gelb, Grün,
  // Blau, Purpur, Grau. We use English everywhere downstream.

  palette: {
    red: {
      900: "#7f1d1d",
      700: "#b91c1c",
      500: "#ef4444",
      300: "#fca5a5",
      100: "#fee2e2",
    },
    orange: {
      900: "#7c2d12",
      700: "#c2410c",
      500: "#f97316",
      300: "#fdba74",
      100: "#ffedd5",
    },
    yellow: {
      900: "#713f12",
      700: "#a16207",
      500: "#eab308",
      300: "#fde047",
      100: "#fef9c3",
    },
    green: {
      900: "#365314",
      700: "#4d7c0f",
      500: "#84cc16",
      300: "#bef264",
      100: "#ecfccb",
    },
    blue: {
      900: "#1e3a8a",
      700: "#1d4ed8",
      500: "#3b82f6",
      300: "#93c5fd",
      100: "#dbeafe",
    },
    purple: {
      900: "#581c87",
      700: "#7e22ce",
      500: "#a855f7",
      300: "#d8b4fe",
      100: "#f3e8ff",
    },
    gray: {
      900: "#171717",
      700: "#404040",
      500: "#737373",
      300: "#d4d4d4",
      100: "#f5f5f5",
    },

    // Extension hue — RESERVED for use cases where the protocol or
    // convention explicitly requires cyan (terminal ANSI cyan, git
    // diff hunk headers, etc.). NOT part of the variant axis. NOT in
    // the default syntax token map.
    cyan: {
      900: "#164e63",
      700: "#0e7490",
      500: "#06b6d4",
      300: "#67e8f9",
      100: "#cffafe",
    },
  },

  // ────────────────────────────────────────────────────────────────
  //   2.  VARIANT HUES  —  the 6 hues exposed as accent variants
  // ────────────────────────────────────────────────────────────────
  // Cyan deliberately excluded. The order here is canonical and
  // matches the pinwheel wedge order in assets/logo.svg.

  variant_hues: ["red", "orange", "yellow", "green", "blue", "purple"],

  // ────────────────────────────────────────────────────────────────
  //   3.  ACCENT-SHADE RULESET  —  flavor × hue → shade index
  // ────────────────────────────────────────────────────────────────
  // Per the rule: "Pick the shade in the opposite half of the
  // lightness scale from the bg, one step in from the extreme
  // (300/700) by default. Step further (100/900) only when the hue's
  // intrinsic luminance is too close to the background."
  //
  // All 24 combinations clear WCAG 2.1 AA (≥ 4.5 : 1) against their
  // flavor background.

  accent_shade: {
    midnight: {
      red: 500,
      orange: 500,
      yellow: 500,
      green: 500,
      blue: 300,
      purple: 300,
    },
    twilight: {
      red: 300,
      orange: 300,
      yellow: 500,
      green: 500,
      blue: 300,
      purple: 300,
    },
    dawn: {
      red: 900,
      orange: 900,
      yellow: 900,
      green: 900,
      blue: 700,
      purple: 700,
    },
    noon: {
      red: 700,
      orange: 700,
      yellow: 900,
      green: 900,
      blue: 700,
      purple: 700,
    },
  },

  // ────────────────────────────────────────────────────────────────
  //   4.  FLAVORS  —  the 4 base themes
  // ────────────────────────────────────────────────────────────────
  // Each flavor defines:
  //   surface  — background layers (bg / lifted / sunk / overlay / scrim)
  //   text     — foreground layers
  //   border   — border weights
  //   state    — interaction states (hover/active/disabled) as alpha overlays
  //   semantic — success/warning/danger/info
  //   syntax   — the 12 core syntax token colors
  //   ansi     — full 16-color terminal ANSI palette

  flavors: {
    // ─── MIDNIGHT (deep dark, OLED-friendly) ───
    midnight: {
      label: "Midnight",
      type: "dark",
      surface: {
        bg: "$palette.gray.900", // #171717
        bg_soft: "$palette.gray.700", // lifted panels
        bg_sunk: "#0a0a0a", // slightly below canvas — outside strict palette
        bg_overlay: "$palette.gray.700", // floating menus, dropdowns
        bg_scrim: "#000000cc", // modal backdrop (80% black)
      },
      text: {
        fg: "$palette.gray.100",
        fg_muted: "$palette.gray.300",
        fg_subtle: "$palette.gray.500",
        fg_disabled: "#525252",
      },
      border: {
        subtle: "#262626", // neutral-800; below palette
        default: "$palette.gray.700",
        strong: "$palette.gray.500",
      },
      state: {
        hover: "#ffffff14", // 8% white overlay
        active: "#ffffff1f", // 12% white overlay
        selection: "#2a2f3a",
      },
      semantic: {
        success: "$palette.green.300",
        warning: "$palette.yellow.300",
        danger: "$palette.red.300",
        info: "$palette.blue.300",
      },
      syntax: {
        comment: "$palette.gray.500",
        keyword: "$palette.purple.300",
        string: "$palette.green.500",
        number: "$palette.orange.500",
        function: "$palette.blue.300",
        parameter: "$palette.orange.300", // NEW (issue #2 item 2) — italic via extended map
        type: "$palette.yellow.500",
        constant: "$palette.orange.500",
        tag: "$palette.blue.300",
        attr: "$palette.green.300", // was yellow.500 (issue #2 item 3)
        regex: "$palette.red.500",
        punct: "$palette.gray.300",
      },
      ansi: {
        black: "#0a0a0a",
        red: "$palette.red.500",
        green: "$palette.green.500",
        yellow: "$palette.yellow.500",
        blue: "$palette.blue.300",
        magenta: "$palette.purple.300",
        cyan: "$palette.cyan.500",
        white: "$palette.gray.300",
        bright_black: "$palette.gray.700",
        bright_red: "$palette.red.300",
        bright_green: "$palette.green.300",
        bright_yellow: "$palette.yellow.300",
        bright_blue: "$palette.blue.300",
        bright_magenta: "$palette.purple.300",
        bright_cyan: "$palette.cyan.300",
        bright_white: "$palette.gray.100",
      },
    },

    // ─── TWILIGHT (classic dark) ───
    twilight: {
      label: "Twilight",
      type: "dark",
      surface: {
        bg: "$palette.gray.700", // #404040
        bg_soft: "#525252", // neutral-600; lifted
        bg_sunk: "$palette.gray.900", // deeper recess
        bg_overlay: "#525252",
        bg_scrim: "#000000bb",
      },
      text: {
        fg: "$palette.gray.100",
        fg_muted: "$palette.gray.300",
        fg_subtle: "#a3a3a3", // neutral-400; readable on #404040
        fg_disabled: "#737373",
      },
      border: {
        subtle: "#525252",
        default: "$palette.gray.900",
        strong: "#0a0a0a",
      },
      state: {
        hover: "#ffffff14",
        active: "#ffffff1f",
        selection: "#5b5b5b",
      },
      semantic: {
        success: "$palette.green.300",
        warning: "$palette.yellow.100",
        danger: "$palette.red.100",
        info: "$palette.blue.100",
      },
      syntax: {
        comment: "#a3a3a3",
        keyword: "$palette.purple.300",
        string: "$palette.green.500",
        number: "$palette.orange.300",
        function: "$palette.blue.300",
        parameter: "$palette.orange.500", // NEW — deeper than number.300 (only available split on this bg)
        type: "$palette.yellow.500",
        constant: "$palette.orange.300",
        tag: "$palette.blue.300",
        attr: "$palette.green.300", // was yellow.500
        regex: "$palette.red.300",
        punct: "$palette.gray.300",
      },
      ansi: {
        black: "$palette.gray.900",
        red: "$palette.red.300",
        green: "$palette.green.500",
        yellow: "$palette.yellow.500",
        blue: "$palette.blue.300",
        magenta: "$palette.purple.300",
        cyan: "$palette.cyan.500",
        white: "$palette.gray.300",
        bright_black: "$palette.gray.500",
        bright_red: "$palette.red.300",
        bright_green: "$palette.green.300",
        bright_yellow: "$palette.yellow.300",
        bright_blue: "$palette.blue.300",
        bright_magenta: "$palette.purple.300",
        bright_cyan: "$palette.cyan.300",
        bright_white: "$palette.gray.100",
      },
    },

    // ─── DAWN (soft light) ───
    dawn: {
      label: "Dawn",
      type: "light",
      surface: {
        bg: "$palette.gray.300", // #d4d4d4
        bg_soft: "$palette.gray.100", // lifted
        bg_sunk: "#bdbdbd", // outside strict palette
        bg_overlay: "$palette.gray.100",
        bg_scrim: "#17171788",
      },
      text: {
        fg: "$palette.gray.900",
        fg_muted: "$palette.gray.700",
        fg_subtle: "#525252",
        fg_disabled: "#737373",
      },
      border: {
        subtle: "#bdbdbd",
        default: "#a3a3a3",
        strong: "$palette.gray.700",
      },
      state: {
        hover: "#0000000d", // 5% black overlay
        active: "#00000014", // 8% black overlay
        selection: "#bdbdbd",
      },
      semantic: {
        success: "$palette.green.900",
        warning: "$palette.yellow.900",
        danger: "$palette.red.900",
        info: "$palette.blue.900",
      },
      syntax: {
        comment: "#525252",
        keyword: "$palette.purple.700",
        string: "$palette.green.900",
        number: "$palette.orange.700",
        function: "$palette.blue.700",
        parameter: "$palette.orange.900", // NEW
        type: "$palette.yellow.900",
        constant: "$palette.orange.700",
        tag: "$palette.blue.700",
        attr: "$palette.green.700", // was yellow.900
        regex: "$palette.red.700",
        punct: "$palette.gray.700",
      },
      ansi: {
        black: "$palette.gray.900",
        red: "$palette.red.700",
        green: "$palette.green.700",
        yellow: "$palette.yellow.700",
        blue: "$palette.blue.700",
        magenta: "$palette.purple.700",
        cyan: "$palette.cyan.700",
        white: "$palette.gray.300",
        bright_black: "$palette.gray.500",
        bright_red: "$palette.red.900",
        bright_green: "$palette.green.900",
        bright_yellow: "$palette.yellow.900",
        bright_blue: "$palette.blue.900",
        bright_magenta: "$palette.purple.900",
        bright_cyan: "$palette.cyan.900",
        bright_white: "$palette.gray.100",
      },
    },

    // ─── NOON (crisp light) ───
    noon: {
      label: "Noon",
      type: "light",
      surface: {
        bg: "$palette.gray.100", // #f5f5f5
        bg_soft: "#ffffff",
        bg_sunk: "$palette.gray.300",
        bg_overlay: "#ffffff",
        bg_scrim: "#17171788",
      },
      text: {
        fg: "$palette.gray.900",
        fg_muted: "$palette.gray.700",
        fg_subtle: "#525252",
        fg_disabled: "#737373",
      },
      border: {
        subtle: "#e5e5e5",
        default: "$palette.gray.300",
        strong: "$palette.gray.500",
      },
      state: {
        hover: "#0000000d",
        active: "#00000014",
        selection: "#e5e5e5",
      },
      semantic: {
        success: "$palette.green.900",
        warning: "$palette.yellow.900",
        danger: "$palette.red.900",
        info: "$palette.blue.900",
      },
      syntax: {
        comment: "#525252",
        keyword: "$palette.purple.700",
        string: "$palette.green.900",
        number: "$palette.orange.700",
        function: "$palette.blue.700",
        parameter: "$palette.orange.900", // NEW
        type: "$palette.yellow.900",
        constant: "$palette.orange.700",
        tag: "$palette.blue.700",
        attr: "$palette.green.700", // was yellow.900
        regex: "$palette.red.700",
        punct: "$palette.gray.700",
      },
      ansi: {
        black: "$palette.gray.900",
        red: "$palette.red.700",
        green: "$palette.green.700",
        yellow: "$palette.yellow.700",
        blue: "$palette.blue.700",
        magenta: "$palette.purple.700",
        cyan: "$palette.cyan.700",
        white: "$palette.gray.700",
        bright_black: "$palette.gray.500",
        bright_red: "$palette.red.900",
        bright_green: "$palette.green.900",
        bright_yellow: "$palette.yellow.900",
        bright_blue: "$palette.blue.900",
        bright_magenta: "$palette.purple.900",
        bright_cyan: "$palette.cyan.900",
        bright_white: "$palette.gray.300",
      },
    },
  },

  // ────────────────────────────────────────────────────────────────
  //   5.  TYPOGRAPHY
  // ────────────────────────────────────────────────────────────────
  // Three families. Cascadia Code for monospace (user's pick).
  // IBM Plex Sans + Serif for everything else — they're free, ship
  // matched sans/serif/mono faces (and Plex Mono is the closest
  // free alt to Cascadia if anyone wants a fully unified port).

  typography: {
    // Atkinson Hyperlegible — designed by the Braille Institute for
    // readers with low vision. Aligns with the system's WCAG-first
    // posture: every variant is contrast-verified, every face is
    // engineered for distinguishability between similar glyphs.
    //
    // The family ships only Sans + Mono (no serif). We deliberately
    // do NOT pair a third-party serif: keeping the brand to one family
    // is more important than completeness.
    families: {
      sans: {
        primary: "Atkinson Hyperlegible Next",
        weights: [200, 300, 400, 500, 600, 700, 800],
        variable: true,
        stack: '"Atkinson Hyperlegible Next", ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif',
        source: "https://www.brailleinstitute.org/freefont",
        license: "OFL-1.1",
        files: [
          "fonts/AtkinsonHyperlegibleNext-VariableFont_wght.ttf",
          "fonts/AtkinsonHyperlegibleNext-Italic-VariableFont_wght.ttf",
        ],
      },
      mono: {
        primary: "Atkinson Hyperlegible Mono",
        weights: [200, 300, 400, 500, 600, 700, 800],
        variable: true,
        stack: '"Atkinson Hyperlegible Mono", "Cascadia Code", "Cascadia Mono", ui-monospace, Menlo, Consolas, monospace',
        source: "https://www.brailleinstitute.org/freefont",
        license: "OFL-1.1",
        files: [
          "fonts/AtkinsonHyperlegibleMono-VariableFont_wght.ttf",
          "fonts/AtkinsonHyperlegibleMono-Italic-VariableFont_wght.ttf",
        ],
        notes: "Cascadia Code kept in the stack as a fallback — respects the user's personal coding-font preference where it's installed locally.",
        nerd_font_variant: {
          name: "Atkinson Hyperlegible Mono Nerd Font",
          source: "https://www.nerdfonts.com/font-downloads",
          notes: "Port-side asset, not bundled here. Terminal ports (Alacritty, Kitty, iTerm, …) should recommend this variant so icon-using prompts like Starship and Powerlevel10k render correctly. Not used by the design system itself.",
        },
      },
    },

    weights: {
      regular: 400,
      medium: 500,
      semibold: 600,
      bold: 700,
    },

    // Logical type styles. Each entry is consumable directly.
    // size_px is the design size at 1× zoom; clients may scale.
    scale: {
      display_xl: {
        family: "sans",
        size_px: 48,
        line_height: 1.1,
        weight: 700,
        tracking: "-0.02em",
      },
      display_lg: {
        family: "sans",
        size_px: 36,
        line_height: 1.15,
        weight: 700,
        tracking: "-0.02em",
      },
      display_md: {
        family: "sans",
        size_px: 28,
        line_height: 1.2,
        weight: 600,
        tracking: "-0.015em",
      },
      heading: {
        family: "sans",
        size_px: 20,
        line_height: 1.3,
        weight: 600,
        tracking: "-0.01em",
      },
      body: {
        family: "sans",
        size_px: 16,
        line_height: 1.5,
        weight: 400,
        tracking: "0",
      },
      body_sm: {
        family: "sans",
        size_px: 14,
        line_height: 1.5,
        weight: 400,
        tracking: "0",
      },
      caption: {
        family: "sans",
        size_px: 12,
        line_height: 1.4,
        weight: 500,
        tracking: "0.02em",
      },
      label: {
        family: "sans",
        size_px: 11,
        line_height: 1.3,
        weight: 600,
        tracking: "0.08em",
        text_transform: "uppercase",
      },
      blockquote: {
        family: "sans",
        size_px: 18,
        line_height: 1.6,
        weight: 400,
        tracking: "0",
        italic: true,
      },
      code: {
        family: "mono",
        size_px: 14,
        line_height: 1.5,
        weight: 400,
        tracking: "0",
      },
      code_sm: {
        family: "mono",
        size_px: 12,
        line_height: 1.45,
        weight: 400,
        tracking: "0",
      },
    },
  },

  // ────────────────────────────────────────────────────────────────
  //   6.  SPACING  —  4px base scale
  // ────────────────────────────────────────────────────────────────
  // Keys are scale-step numbers; values are pixel strings.
  // Use these for padding, margin, gap. Skip 7, 9, 11 etc by design
  // (the scale should not grow linearly past a point).

  spacing: {
    px: "1px",
    0: "0",
    1: "4px",
    2: "8px",
    3: "12px",
    4: "16px",
    5: "20px",
    6: "24px",
    8: "32px",
    10: "40px",
    12: "48px",
    16: "64px",
    20: "80px",
    24: "96px",
  },

  // ────────────────────────────────────────────────────────────────
  //   7.  RADII
  // ────────────────────────────────────────────────────────────────

  radii: {
    none: "0",
    sm: "4px",
    md: "8px",
    lg: "12px",
    xl: "16px",
    pill: "9999px",
  },

  // ────────────────────────────────────────────────────────────────
  //   8.  ELEVATION / SHADOW
  // ────────────────────────────────────────────────────────────────
  // 3 levels. Same shadow values across flavors — they read fine on
  // both light & dark surfaces because the alpha is what carries.

  shadows: {
    sm: "0 1px 2px rgba(0,0,0,0.08)",
    md: "0 4px 12px rgba(0,0,0,0.12), 0 1px 3px rgba(0,0,0,0.06)",
    lg: "0 12px 32px rgba(0,0,0,0.18), 0 4px 8px rgba(0,0,0,0.08)",

    // Inset / focus-ring helpers
    focus_ring_width: "2px",
    focus_ring_offset: "2px",
  },

  // ────────────────────────────────────────────────────────────────
  //   9.  MOTION
  // ────────────────────────────────────────────────────────────────

  motion: {
    duration: {
      instant: "0ms",
      fast: "120ms",
      base: "200ms",
      slow: "320ms",
    },
    easing: {
      standard: "cubic-bezier(0.2, 0, 0, 1)",
      enter: "cubic-bezier(0, 0, 0.2, 1)",
      exit: "cubic-bezier(0.4, 0, 1, 1)",
    },
  },

  // ────────────────────────────────────────────────────────────────
  //   10.  SYNTAX TOKEN MAP  —  logical → concrete
  // ────────────────────────────────────────────────────────────────
  // The 12 "core" tokens are defined directly on each flavor (see
  // flavors.*.syntax) and emit as `--syn-<name>` CSS variables.
  //
  // Extended tokens map a logical name to either:
  //   • a string shorthand — resolves to { color: <string> }
  //   • { color?, style? } — color target + optional font-style array
  //
  // `color` target vocabulary:
  //   • core slot name (comment, keyword, …, parameter, …, punct)
  //   • fg, fg_muted, fg_subtle, fg_disabled  (→ flavors.*.text.*)
  //   • semantic.success | .warning | .danger | .info  (→ flavors.*.semantic.*)
  //
  // `style` values: "italic" | "bold" | "underline"
  // A missing `color` means style-only (inherits host text color).
  //
  // Ports do their own resolution at build time; the foundation
  // ships this map as metadata.

  syntax_tokens: {
    core: [
      "comment",
      "keyword",
      "string",
      "number",
      "function",
      "parameter",
      "type",
      "constant",
      "tag",
      "attr",
      "regex",
      "punct",
    ],
    extended: {
      // ── Repurposed ────────────────────────────────────────────
      variable: "fg",
      parameter: { color: "parameter", style: ["italic"] },
      property: "fg", // obj.foo, css property — was → "tag"
      decorator: { color: "function", style: ["italic"] }, // @foo, #[attr] — meta layer

      // ── Unchanged ────────────────────────────────────────────
      operator: "keyword", // +, -, =, =>, |
      builtin: { color: "function", style: ["italic"] }, // print, len, console.log — "not yours"
      namespace: "type", // module / namespace paths
      macro: "function", // println!, vec!
      lifetime: "constant", // Rust 'a, 'static
      heading: { color: "keyword", style: ["bold"] }, // markdown # ## ### — structural anchor
      link: "tag", // markdown [text](url)
      selector: "tag", // css .foo, :root
      unit: "number", // css 16px, 200ms
      hex: "string", // css #fff, #abc123
      shebang: "comment", // #!/usr/bin/env bash

      // ── New ───────────────────────────────────────────────────
      lang_var: { color: "constant", style: ["italic"] }, // this/self/super — language-provided
      emphasis: { color: "type", style: ["italic"] }, // markup.italic + markdown/rst/asciidoc emphasis
      strong: { color: "number", style: ["bold"] }, // markup.bold + markdown/rst/asciidoc strong
      invalid: { color: "semantic.danger", style: ["italic", "underline"] },
      invalid_deprecated: { color: "fg", style: ["italic", "underline"] },
      doc_keyword: "keyword", // JSDoc @param, @returns, etc.
      doc_type: { color: "type", style: ["italic"] },
      doc_param: { color: "parameter", style: ["italic"] },
      event: "function", // named event/signal (onClick, onError) — treat like a function
      label: { color: "fg", style: ["italic"] }, // goto/break label — rare, mark as unusual
    },
  },

  // ────────────────────────────────────────────────────────────────
  //   11.  SCOPE RECOMMENDATIONS  —  TextMate scope → logical slot
  // ────────────────────────────────────────────────────────────────
  // Per-slot lists of TextMate scopes that ports SHOULD map to that
  // slot when generating tokenColors rules. Optional — ports may extend
  // or override based on their target's grammar coverage.

  scope_recommendations: {
    // Per-slot TextMate scope lists. Ports SHOULD map these scopes to
    // the named slot when generating tokenColors rules. Lists are ordered
    // from most specific (prefer) to most general (fallback).
    // Use VS Code "Developer: Inspect Editor Tokens and Scopes" to
    // confirm the exact scope stack for any token before writing a rule.

    // ── Core tokens ───────────────────────────────────────────────────
    comment: ["comment", "comment.line", "comment.block"],
    keyword: [
      "keyword.control",
      "keyword.other",
      "storage.type",
      "storage.modifier",
    ],
    string: ["string", "string.quoted", "string.template"],
    number: [
      "constant.numeric",
      "constant.language", // true, false, null, undefined
    ],
    function: ["entity.name.function", "support.function"],
    parameter: ["variable.parameter"],
    type: [
      "entity.name.type",
      "entity.name.class",
      "support.class",
      "support.type",
    ],
    constant: [
      "constant.other",
      // NOTE: variable.other.constant.{js,ts,tsx} → fg; see fg_fallthrough_jsts
    ],
    tag: ["entity.name.tag"],
    attr: ["entity.other.attribute-name"],
    regex: ["string.regexp"],
    punct: ["punctuation"],

    // ── Extended tokens ───────────────────────────────────────────────
    variable: ["variable.other.readwrite", "variable.other"],
    property: [
      "variable.other.property",
      "variable.other.member",
      "support.type.property-name",
    ],
    decorator: [
      "entity.name.function.decorator",
      "meta.decorator entity.name.function",
      "punctuation.decorator",
    ],
    operator: ["keyword.operator"],
    builtin: [
      "support.function.builtin",
      "support.class.builtin",
      "support.variable.builtin",
    ],
    namespace: ["entity.name.namespace", "entity.name.module"],
    macro: ["entity.name.function.macro", "support.function.macro"],
    lifetime: ["storage.modifier.lifetime.rust", "entity.name.lifetime.rust"],
    heading: [
      "markup.heading",
      "entity.name.section",
      "punctuation.definition.heading",
    ],
    link: ["markup.underline.link", "string.other.link"],
    selector: [
      "entity.other.pseudo-class",
      "entity.other.pseudo-element",
      "meta.selector entity.other.attribute-name",
    ],
    unit: ["keyword.other.unit"],
    hex: ["constant.other.color", "constant.other.color.rgb-value.css"],
    shebang: ["comment.line.shebang"],
    emphasis: ["markup.italic"],
    strong: ["markup.bold"],
    invalid: ["invalid.illegal"],
    invalid_deprecated: ["invalid.deprecated"],
    event: ["variable.other.event", "support.type.event"],
    label: ["entity.name.label", "variable.label"],

    // ── Specific overrides ────────────────────────────────────────────
    // language-level pronouns (not function calls)
    lang_var: [
      "variable.language.this",
      "variable.language.self",
      "variable.language.super",
    ],

    // JSDoc / doc-comment children
    doc_keyword: ["comment.block.documentation keyword"],
    doc_type: ["comment.block.documentation entity.name.type"],
    doc_param: ["comment.block.documentation variable"],

    // In JS/TS, `const x = …` is the default declaration form and should
    // NOT inherit the `constant` color (that would color every const noisily).
    // Map these scopes to `fg`. The language-server `variable.readonly`
    // semantic token should still resolve to the `constant` slot.
    fg_fallthrough_jsts: [
      "variable.other.constant.js",
      "variable.other.constant.ts",
      "variable.other.constant.tsx",
    ],
  },

  // ────────────────────────────────────────────────────────────────
  //   12.  SEMANTIC TOKEN RECOMMENDATIONS
  //         VS Code LSP semantic token types → design system slots
  // ────────────────────────────────────────────────────────────────
  // Define semanticTokenColors entries alongside tokenColors.
  // When a semantic rule and a TextMate rule conflict, semantic wins.
  // Selector syntax: (tokenType)(.modifier)*(:language)?
  //   "variable"           all variables, any language
  //   "*.readonly"         all readonly tokens, any type
  //   "class:java"         classes in Java only
  //   "variable.readonly"  read-only variables, any language

  semantic_token_recommendations: {
    // ── 24 standard token types ───────────────────────────────────────
    // Color targets reference the same slot names as syntax_tokens.extended.
    // Ports resolve each slot to the per-flavor hex at build time.
    types: {
      namespace: "type",
      class: "type",
      enum: "type",
      interface: "type",
      struct: "type",
      typeParameter: "parameter", // generic <T> — orange; distinct from concrete type
      type: "type",
      parameter: { color: "parameter", style: ["italic"] },
      variable: "fg",
      property: "fg",
      enumMember: "constant",
      decorator: { color: "function", style: ["italic"] },
      event: "function",
      function: "function",
      method: "function",
      macro: "function",
      label: { color: "fg", style: ["italic"] },
      comment: { color: "comment", style: ["italic"] },
      string: "string",
      keyword: "keyword",
      number: "number",
      regexp: "regex",
      operator: "keyword",
    },

    // ── 11 semantic token modifiers ───────────────────────────────────
    // A modifier overrides ONLY the specified properties; all other
    // properties inherit from the base type mapping above.
    // Use selector "*.modifier" in semanticTokenColors for global rules.
    // "none" = no additional style beyond the base type.
    modifiers: {
      declaration: "none",
      definition: "none",
      readonly: { color: "constant" }, // treat as a named constant
      static: "none",
      deprecated: { style: ["italic", "underline"] },
      abstract: { style: ["italic"] }, // marks incomplete / virtual
      async: "none",
      modification: { color: "number" }, // orange — aligns with diff-modified
      documentation: { color: "comment" },
      defaultLibrary: { style: ["italic"] }, // "not yours"
    },
  },

  // ────────────────────────────────────────────────────────────────
  //   13.  WORKBENCH COLOR ROLES  —  UI chrome / editor chrome
  // ────────────────────────────────────────────────────────────────
  // Maps design-system tokens to VS Code workbench color categories.
  // Use the SAME hue for each severity role everywhere it appears:
  // squiggles, gutter, overview ruler, status bar, minimap, panel.
  //
  // Alpha compositing for diff / overlay backgrounds:
  //   use alphaOver(color, flavor_bg, alpha) from tools/build-tokens.mjs
  //   to bake a concrete hex value at port build time.

  workbench_color_roles: {
    // ── Signals (error / warning / info / success) ────────────────────
    signals: {
      error: "semantic.danger",
      warning: "semantic.warning",
      info: "semantic.info",
      hint: "semantic.info",
      success: "semantic.success",
    },

    // ── Git decorations ───────────────────────────────────────────────
    // Apply identically to: gitDecoration.*, editorGutter.*,
    // editorOverviewRuler.*, minimapGutter.*, diffEditor.*
    git: {
      added: "semantic.success",
      modified: "semantic.info",
      deleted: "semantic.danger",
      untracked: "semantic.success",
      ignored: "comment",
      conflicting: "semantic.warning",
    },

    // ── Diff editor ───────────────────────────────────────────────────
    // Alpha values are composited over the flavor's surface.bg.
    // Bake: alphaOver(tokens.flavors[f].semantic[role], tokens.flavors[f].surface.bg, alpha)
    diff: {
      inserted_color: "semantic.success",
      removed_color: "semantic.danger",
      inserted_line_alpha: 0.1,
      inserted_gutter_alpha: 0.2,
      inserted_text_alpha: 0.25,
      removed_line_alpha: 0.1,
      removed_gutter_alpha: 0.2,
      removed_text_alpha: 0.35,
    },

    // ── Bracket pair colorization ─────────────────────────────────────
    // Cycle these design-system slots in level order.
    // Resolve each slot to the per-flavor hex at port build time.
    bracket_pairs: ["fg", "regex", "number", "type", "string", "function"],
    bracket_unexpected: "semantic.danger",
  },

  // ────────────────────────────────────────────────────────────────
  //   14.  ICONOGRAPHY  —  what to use, per layer
  // ────────────────────────────────────────────────────────────────
  // Vivid Life Theme does NOT ship its own icon set. Building one for an
  // IDE + OS + apps would be ~5000 glyphs of work for a generation-
  // behind result. Instead we recommend best-in-class existing sets
  // per layer; ports document the recommendation and pull from CDN /
  // package manager. Every recommendation is monochrome / current-
  // color-able so it reflavors automatically with the theme.

  iconography: {
    // ── Layer C — INLINE UI GLYPHS  (buttons, menus, toolbars) ──
    // The only layer where Vivid Life Theme genuinely owns a visual choice.
    // Use stroke="currentColor" so the icon picks up its container's
    // foreground token — usually --vl-fg, --vl-fg-muted, or --vl-accent.
    inline_ui: {
      primary: {
        name: "Lucide",
        url: "https://lucide.dev/",
        license: "ISC",
        count: "approx 1500 unique glyphs",
        why: "Single-stroke style, forked from Feather specifically to fix small-size legibility. Used by shadcn/ui and most modern design systems. Coherence over coverage.",
        usage: 'Load from CDN, npm (`lucide`, `lucide-react`, `lucide-vue-next`, `lucide-svelte`), or pre-render specific SVGs at build time. All glyphs use stroke="currentColor" — set `color` in CSS to retint.',
      },
      alternative: {
        name: "Tabler Icons",
        url: "https://tabler.io/icons",
        license: "MIT",
        count: "approx 5800 unique glyphs",
        why: "Larger set if you need rarer glyphs (industry-specific, less common UI patterns). Slightly heavier visual weight; mixes outline + filled styles which becomes a per-icon design decision.",
      },
      not_recommended: {
        name: "Phosphor",
        why: "Quoted count (~9k) is 1512 unique glyphs × 6 weights. Smaller actual coverage than Lucide for typical UI needs; weight system is more complexity than the design system needs.",
      },
    },

    // ── Layer B — IDE FILE-TREE / FILETYPE ICONS ──
    // These encode file *type*. They are a visual language users learn
    // across apps. DO NOT recolor file icons with the Vivid Life Theme
    // accent — leave them as-is. Recolor only folder icons (where the
    // target supports it) and chrome.
    ide_filetree: {
      vscode: {
        recommended: "Material Icon Theme",
        url: "https://marketplace.visualstudio.com/items?itemName=PKief.material-icon-theme",
        alt: "Seti (VS Code default) — simpler, fewer file types covered",
        note: "Independent of the color theme. Users install it separately. Catppuccin and Dracula both leave file icons to the user; Vivid Life Theme does too.",
      },
      helix: {
        recommended: "Terminal-side via Nerd Font",
        note: "Helix shows file icons through the terminal emulator's font. Recommend Atkinson Hyperlegible Mono Nerd Font.",
      },
      neovim: {
        recommended: "nvim-web-devicons",
        url: "https://github.com/nvim-tree/nvim-web-devicons",
        note: "Uses the same Nerd Font glyph set; install Atkinson Hyperlegible Mono Nerd Font and pair.",
      },
      jetbrains: {
        recommended: "Built-in icons",
        note: "JetBrains IDEs do not allow user-configurable file icons. Accept the platform default.",
      },
    },

    // ── Layer A — OS / GTK / DESKTOP ──
    // Even larger problem (apps + mimetypes + actions + status icons).
    // Recommend Papirus universally; it already supports per-folder
    // accent recoloring via `papirus-folders`.
    desktop: {
      recommended: "Papirus",
      url: "https://github.com/PapirusDevelopmentTeam/papirus-icon-theme",
      license: "GPL-3.0",
      count: "approx 7000 icons",
      why: "Most popular community icon theme on Linux. Strong monochromatic-ish aesthetic that pairs with Vivid Life Theme without modification. Built-in `papirus-folders` CLI lets users tint folder accents to match their variant.",
      port_recipe: "GTK/Xfce ports should ship a small `papirus-folders` mapping recipe that picks a folder color matching each variant. No icons drawn.",
      alternatives: [
        "Numix Circle — older, more stylized, smaller community",
        "Sweet Icons — works well, smaller community than Papirus",
      ],
    },

    // ── What Vivid Life Theme ships in assets/glyphs/ ──
    // A tiny self-sufficient subset of Lucide for the design system's
    // own previews + future marketing site. Not a substitute for the
    // full set — apps pull Lucide from CDN/npm directly.
    bundled: {
      source: "Lucide v0.x — vendored subset",
      path: "assets/glyphs/",
      note: 'Each SVG uses stroke="currentColor". Container sets `color` to retint. See preview/16-iconography.html for the live spec.',
    },
  },
}
