# EditorConfig — https://editorconfig.org
# Locks indent / EOL / trailing whitespace so every editor produces the
# same byte-output regardless of personal preferences or tooling.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown uses two trailing spaces for hard line breaks.
[*.md]
trim_trailing_whitespace = false
