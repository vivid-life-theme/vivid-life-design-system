{
  "name": "vivid-life-design-system",
  "displayName": "Vivid Life Theme – Design System",
  "description": "A multi-flavor color scheme system. 4 flavors × 6 variants = 24 themes. WCAG AA verified.",
  "version": "0.2.0",
  "license": "MIT",
  "author": {
    "name": "Michael van Laar",
    "email": "michael@van-laar.de"
  },
  "homepage": "https://github.com/vivid-life-theme/vivid-life-design-system",
  "publisher": "vivid-life-theme",
  "repository": {
    "type": "git",
    "url": "https://github.com/vivid-life-theme/vivid-life-design-system"
  },
  "bugs": {
    "url": "https://github.com/vivid-life-theme/vivid-life-design-system/issues"
  },
  "icon": "assets/icon-256.png",
  "keywords": [
    "design-system",
    "design-tokens",
    "color-scheme",
    "theme",
    "wcag",
    "accessibility"
  ],
  "type": "module",
  "main": "./dist/tokens.js",
  "exports": {
    ".": "./dist/tokens.js",
    "./tokens.json": "./tokens.json",
    "./css": "./colors_and_type.css",
    "./fonts/*": "./fonts/*",
    "./assets/*": "./assets/*",
    "./tools/build-tokens": "./tools/build-tokens.mjs"
  },
  "files": [
    "tokens.json5",
    "tokens.json",
    "dist/",
    "colors_and_type.css",
    "fonts/",
    "assets/",
    "tools/",
    "handoff/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "node tools/build-tokens.mjs && node tools/build-css.mjs",
    "check": "node tools/build-tokens.mjs --check && node tools/build-css.mjs --check && node tools/build-previews.mjs --check",
    "test": "node tools/build-tokens.mjs --test"
  },
  "engines": {
    "node": ">=18"
  }
}
